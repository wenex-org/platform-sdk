{
  "name": "@wenex/sdk",
  "version": "0.0.1",
  "description": "Wenex platform SDK.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "debug": "jest --watch",
    "prebuild": "rimraf dist",
    "generate": "graphql-codegen",
    "doc": "typedoc --out docs src/",
    "build": "tsc -p ./tsconfig.json",
    "clean": "rm -rf ./dist && rm -rf ./coverage",
    "lint": "eslint . '*/**/*.{js,ts}' --quiet --fix",
    "format": "prettier --write \"(src|test)/**/*.(ts|js)\"",
    "start:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register src/index.ts",
    "test": "jest && make-coverage-badge --report-path docs/coverage/coverage-summary.json --output-path coverage-badge.svg"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wenex-org/platform-sdk.git"
  },
  "author": "Vahid V.",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/wenex-org/platform-sdk/issues"
  },
  "keywords": [
    "sdk",
    "platform-sdk"
  ],
  "homepage": "https://github.com/wenex-org/platform-sdk#readme",
  "dependencies": {
    "axios": "^1.4.0",
    "debug": "^4.3.4"
  },
  "peerDependencies": {
    "graphql": "^16.7.1",
    "mongoose": "^7.3.1",
    "@apollo/client": "^3.7.16"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^4.0.1",
    "@graphql-codegen/client-preset": "^4.0.1",
    "@types/debug": "^4.1.8",
    "@types/jest": "^29.5.2",
    "@typescript-eslint/eslint-plugin": "^5.60.0",
    "@typescript-eslint/parser": "^5.60.0",
    "dotenv": "^16.3.1",
    "eslint": "^8.43.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-prettier": "^4.2.1",
    "jest": "^29.5.0",
    "jshint": "^2.13.6",
    "make-coverage-badge": "^1.2.0",
    "prettier": "^2.8.8",
    "rimraf": "^5.0.1",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typedoc": "^0.24.8",
    "typescript": "^5.1.3"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "/dist"
  ]
}
